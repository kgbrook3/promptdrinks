# --- Required ---

# Anthropic (Claude) — generates the cocktail name, ingredients, and instructions
ANTHROPIC_API_KEY=sk-ant-...

# Image generation API key (OpenAI by default) — generates the cocktail photo
OPENAI_API_KEY=sk-...

# --- Optional (sensible defaults) ---

# Claude model used for recipe generation
CLAUDE_MODEL=claude-sonnet-4-6

# Image model (OpenAI). e.g. gpt-image-1 or dall-e-3
IMAGE_MODEL=gpt-image-1

# Image size, e.g. 1024x1024
IMAGE_SIZE=1024x1024

# gpt-image-1 quality: low | medium | high. "low" is fastest (stays under the
# serverless function timeout). Ignored for dall-e-3.
IMAGE_QUALITY=low
